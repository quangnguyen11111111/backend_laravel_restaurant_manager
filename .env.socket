# Socket Server Environment Configuration
# Sao chép file này vào .env hoặc tham khảo các giá trị

# WebSocket Server Port
SOCKET_PORT=3001

# Laravel API URL (Socket Server sẽ gọi API này)
LARAVEL_API_URL=http://localhost:8000/api

# Socket Server URL (Frontend sẽ kết nối tới đây)
SOCKET_SERVER_URL=http://localhost:3001

# Frontend URL (cho CORS)
FRONTEND_URL=http://localhost:3000

# Node Environment
NODE_ENV=development

# ========== Additional Settings ==========

# Socket.io Configuration
SOCKET_TRANSPORTS=websocket,polling

# JWT Token Verification (từ Laravel backend)
# Được sử dụng khi Socket Server verify token với Laravel
ACCESS_TOKEN_SECRET=your-access-token-secret

# Logging
LOG_LEVEL=debug

# ========== Production Settings ==========
# Uncomment những dòng này khi deploy

# SOCKET_PORT=443
# LARAVEL_API_URL=https://api.yourdomain.com/api
# SOCKET_SERVER_URL=wss://socket.yourdomain.com
# FRONTEND_URL=https://yourdomain.com
# NODE_ENV=production
# LOG_LEVEL=info
# SOCKET_TRANSPORTS=websocket
